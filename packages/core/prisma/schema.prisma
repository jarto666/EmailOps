datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dataConnectors          DataConnector[]
  emailProviderConnectors EmailProviderConnector[]
  ingestApiKeys           IngestApiKey[]
  subjects                Subject[]
  events                  Event[]
  journeys                Journey[]
  enrollments             Enrollment[]
  senderProfiles SenderProfile[]
  templates      Template[]
  segments       Segment[]
  singleSends    SingleSend[]
  suppressions   Suppression[]
  preferences    Preference[]
}

model IngestApiKey {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  secret      Json      // Encrypted secret
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@index([workspaceId])
}

model Subject {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // Canonical identity from customer's app (e.g. userId)
  subjectId String
  email     String?
  traits    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]
  enrollments Enrollment[]

  @@unique([workspaceId, subjectId])
}

model Event {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  subjectPkId String
  subject     Subject   @relation(fields: [subjectPkId], references: [id])

  name          String
  occurredAt    DateTime
  properties    Json?
  idempotencyKey String

  createdAt DateTime @default(now())

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, subjectPkId, name, occurredAt])
}

enum JourneyStatus {
  DRAFT
  RUNNING
  PAUSED
  ARCHIVED
}

enum JourneyNodeType {
  ENTRY_EVENT
  DELAY
  CONDITION
  SEND_EMAIL
  EXIT
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum StepStatus {
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Journey {
  id          String       @id @default(uuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  name        String
  status      JourneyStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  versions JourneyVersion[]
}

model JourneyVersion {
  id          String    @id @default(uuid())
  journeyId   String
  journey     Journey   @relation(fields: [journeyId], references: [id])
  version     Int
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  nodes       JourneyNode[]
  edges       JourneyEdge[]
  enrollments Enrollment[]

  @@unique([journeyId, version])
}

model JourneyNode {
  id              String         @id @default(uuid())
  journeyVersionId String
  journeyVersion  JourneyVersion @relation(fields: [journeyVersionId], references: [id])
  nodeKey         String
  type            JourneyNodeType
  config          Json?

  @@unique([journeyVersionId, nodeKey])
}

model JourneyEdge {
  id              String         @id @default(uuid())
  journeyVersionId String
  journeyVersion  JourneyVersion @relation(fields: [journeyVersionId], references: [id])
  fromNodeKey     String
  toNodeKey       String
  condition       Json?

  @@index([journeyVersionId, fromNodeKey])
}

model Enrollment {
  id              String         @id @default(uuid())
  journeyVersionId String
  journeyVersion  JourneyVersion @relation(fields: [journeyVersionId], references: [id])
  workspaceId     String
  workspace       Workspace      @relation(fields: [workspaceId], references: [id])

  subjectPkId String
  subject     Subject @relation(fields: [subjectPkId], references: [id])

  status    EnrollmentStatus @default(ACTIVE)
  enteredAt DateTime         @default(now())
  exitedAt  DateTime?
  dedupeKey String

  steps StepExecution[]

  @@unique([journeyVersionId, dedupeKey])
  @@index([workspaceId, subjectPkId, status])
}

model StepExecution {
  id           String      @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id])
  nodeKey      String
  status       StepStatus  @default(SCHEDULED)
  scheduledAt  DateTime    @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  attempts     Int         @default(0)
  error        String?
  createdAt    DateTime    @default(now())

  @@unique([enrollmentId, nodeKey])
  @@index([status, scheduledAt])
}

enum DataConnectorType {
  POSTGRES
  BIGQUERY
}

model DataConnector {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])
  type        DataConnectorType
  name        String
  config      Json          // Encrypted credentials or config
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  segments       Segment[]
}

enum EmailProviderType {
  SES
  RESEND
  SMTP
}

model EmailProviderConnector {
  id          String            @id @default(uuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  type        EmailProviderType
  name        String
  config      Json              // Encrypted credentials or config
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  senderProfiles SenderProfile[]
}

model SenderProfile {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  emailProviderConnectorId String
  emailProviderConnector   EmailProviderConnector @relation(fields: [emailProviderConnectorId], references: [id])
  fromEmail   String
  fromName    String?
  replyTo     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  singleSends SingleSend[]
}

enum TemplateCategory {
  MARKETING
  TRANSACTIONAL
  BOTH
}

model Template {
  id          String           @id @default(uuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id])
  key         String           @unique // e.g. "welcome-email"
  name        String
  category    TemplateCategory
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  versions  TemplateVersion[]
  singleSends SingleSend[]
}

enum AuthoringMode {
  RAW_HTML
  RAW_MJML
  UI_BUILDER
}

model TemplateVersion {
  id            String        @id @default(uuid())
  templateId    String
  template      Template      @relation(fields: [templateId], references: [id])
  name          String        // e.g. "v1.0"
  subject       String
  bodyHtml      String?       // Final compiled HTML
  bodyMjml      String?       // Source MJML if applicable
  builderSchema Json?         // Source JSON if Builder
  mode          AuthoringMode
  active        Boolean       @default(false)
  createdAt     DateTime      @default(now())

  // We might want to link campaigns to specific versions in the future
  // For now, SingleSend points to Template and uses active version
}

model Segment {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String
  sqlQuery    String
  dataConnectorId String
  dataConnector   DataConnector @relation(fields: [dataConnectorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  singleSends SingleSend[]
}

enum SingleSendStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
  COMPLETED
}

enum ScheduleType {
  MANUAL
  CRON
}

model SingleSend {
  id              String           @id @default(uuid())
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id])
  name            String
  description     String?
  status          SingleSendStatus @default(DRAFT)
  templateId      String
  template        Template         @relation(fields: [templateId], references: [id])
  segmentId       String
  segment         Segment          @relation(fields: [segmentId], references: [id])
  senderProfileId String
  senderProfile   SenderProfile    @relation(fields: [senderProfileId], references: [id])
  scheduleType    ScheduleType     @default(MANUAL)
  cronExpression  String?
  policies        Json?            // e.g. { rateLimitPerSecond: 10 }
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  runs SingleSendRun[]
}

enum SingleSendRunStatus {
  CREATED
  AUDIENCE_BUILDING
  AUDIENCE_READY
  SENDING
  COMPLETED
  FAILED
}

model SingleSendRun {
  id           String            @id @default(uuid())
  singleSendId String
  singleSend   SingleSend        @relation(fields: [singleSendId], references: [id])
  status       SingleSendRunStatus @default(CREATED)
  stats        Json?             // { total: 100, inserted: 100, sent: 90, failed: 10 }
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())

  recipients SingleSendRecipient[]
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model SingleSendRecipient {
  id          String          @id @default(uuid())
  runId       String
  run         SingleSendRun   @relation(fields: [runId], references: [id])
  subjectId   String          // From Segment (canonical identity from customer app)
  email       String
  vars        Json?
  status      RecipientStatus @default(PENDING)
  skipReason  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sends Send[]

  @@unique([runId, subjectId]) // Idempotency within run
}

enum SendStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  COMPLAINT
  FAILED
}

model Send {
  id                String       @id @default(uuid())
  singleSendRecipientId    String?
  singleSendRecipient      SingleSendRecipient? @relation(fields: [singleSendRecipientId], references: [id])
  workspaceId       String // Denormalized for quick access? Or rely on join?
  // Ideally link to transactional requests too if we store them
  
  idempotencyKey    String       @unique
  status            SendStatus   @default(QUEUED)
  providerMessageId String?
  attempts          Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

enum SuppressionReason {
  BOUNCE
  COMPLAINT
  UNSUBSCRIBE
  MANUAL
}

model Suppression {
  id          String            @id @default(uuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  email       String
  reason      SuppressionReason
  createdAt   DateTime          @default(now())

  @@unique([workspaceId, email])
}

model Preference {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  email       String
  category    String    // e.g. "marketing", "updates"
  optedIn     Boolean   @default(true)
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, email, category])
}

model DeadLetter {
  id        String   @id @default(uuid())
  jobId     String?
  queueName String
  payload   Json
  error     String?
  createdAt DateTime @default(now())
}
